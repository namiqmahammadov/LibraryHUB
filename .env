# ==========================
# PostgreSQL - Users Service
# ==========================
USERS_DB_NAME=users_db
USERS_DB_USER=postgres
USERS_DB_PASSWORD=passsword
USERS_DB_HOST_PORT=5432

# ==========================
# PostgreSQL - Books Service
# ==========================
BOOKS_DB_NAME=books_db
BOOKS_DB_USER=postgres
BOOKS_DB_PASSWORD=passsword
BOOKS_DB_HOST_PORT=5433

# ==========================
# Redis
# ==========================
REDIS_HOST_PORT=6379

# ==========================
# RabbitMQ
# ==========================
RABBITMQ_DEFAULT_USER=namiq
RABBITMQ_DEFAULT_PASS=12345
RABBITMQ_HOST_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ==========================
# Spring Boot Services
# ==========================
MS_USER_PORT=8081
MS_BOOK_PORT=8082

# ==========================
# Docker Hub Images
# ==========================
MS_USER_IMAGE=namiqmahammadov/ms-user:latest
MS_BOOK_IMAGE=namiqmahammadov/ms-book:latest